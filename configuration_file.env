# ==========================================
# Marley Health Installation Configuration
# ==========================================

# Database Credentials
# Change these to strong passwords before installing!
MARIADB_ROOT_PASS=MarleyRootDBPass!23

# Admin Password (For ERPNext/Marley Web Login)
ADMIN_PASS=MarleyAdminPass!23

# Site Name
# If you have a live domain (e.g., health.myhospital.com), put it here.
# Otherwise, keep it as local for testing.
SITE_NAME=marley.local

# OS User under which the Frappe Bench will run
FRAPPE_USER=frappe

# Frappe & App Branches (v16)
FRAPPE_BRANCH=version-16